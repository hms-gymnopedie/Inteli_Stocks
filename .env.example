# Copy this file to .env and fill in real values.
# .env is gitignored — never commit actual keys.
#
# Categories:
#   REQUIRED        — none; yahoo-finance2 works key-free.
#   AI PROVIDERS    — enables AI signals, verdicts, hedge suggestions, geo insights.
#   AUTH/STORAGE    — enables multi-user auth + cloud-backed portfolio sync.
#   INTEGRATIONS    — Slack alerts, Google Sheets mirror, extra market data.
#   RUNTIME         — server behaviour tuning.


# ── AI PROVIDERS ──────────────────────────────────────────────────────────────
# At least one must be set for AI features to work. The Tweaks panel's
# "AI Provider" selector only shows providers whose key is configured.

# Anthropic Claude — powers AI signals, verdicts, hedge proposals, insights.
# Get key: https://console.anthropic.com/keys
ANTHROPIC_API_KEY=

# Google Gemini — alternative AI provider; also drives geo-risk grounded search
# (Fear & Greed, geopolitical hotspots via web grounding).
# Get free key: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=


# ── AUTH / STORAGE ────────────────────────────────────────────────────────────
# All three Supabase vars must be set together to enable multi-user auth and
# cloud-backed portfolio storage. Without them the app runs in local-file mode
# (no login screen; portfolio stored in ~/.intelistock/ or /data/intelistock/ in Docker).
# Get values: https://supabase.com → your project → Settings → API

# Your Supabase project URL, e.g. https://xyzxyz.supabase.co
SUPABASE_URL=

# Public anon key (safe to expose client-side — returned by /api/auth/config).
SUPABASE_ANON_KEY=

# Service role key (server-only — validates JWTs and writes portfolios).
# NEVER expose this to the browser.
SUPABASE_SERVICE_ROLE_KEY=


# ── INTEGRATIONS ──────────────────────────────────────────────────────────────

# FRED API — macroeconomic data (CPI, Fed Funds Rate, etc.).
# Without this key, macro cards fall back to mock values.
# Get free key: https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=

# Finnhub — economic calendar + options IV surface.
# Without this key, calendar and IV surface fall back to mock data.
# Free tier: 60 calls/min. Register: https://finnhub.io/register
FINNHUB_API_KEY=

# Slack — incoming webhook URL for portfolio sell-trigger alerts.
# Create at: https://api.slack.com/apps → Your App → Incoming Webhooks.
SLACK_WEBHOOK_URL=

# Google Sheets — mirrors portfolio writes to a Google Sheets spreadsheet.
# Local JSON remains the source of truth; Sheets is append-only.
# Setup:
#   1. https://console.cloud.google.com → APIs & Services → Enable Google Sheets API.
#   2. Configure OAuth consent screen (External, Testing — add yourself as test user).
#   3. Create OAuth 2.0 Client ID, type = Web application.
#   4. Add http://localhost:3001/api/google/callback to "Authorized redirect URIs".
#   5. Paste Client ID / Secret here, then click "Connect Google" in /settings.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Optional overrides (defaults work for local/Docker setup).
# GOOGLE_REDIRECT_URI=http://localhost:3001/api/google/callback
# GOOGLE_APP_URL=http://localhost:5180/settings


# ── RUNTIME ───────────────────────────────────────────────────────────────────

# Server port (default: 3001).
# PORT=3001

# Set to "off" to disable the hourly background sync cron job
# (e.g. in read-only or CI environments).
# CRON_DAILY_SYNC=off

# Timezone for synced_at timestamps in Google Sheets and cron heartbeat.
# Any IANA timezone ID. Default: America/New_York.
# TIMEZONE=America/New_York
