# Copy this file to .env and fill in real values.
# .env is gitignored — never commit actual keys.

# AI providers — set the keys for the providers you want to use.
# At least one must be configured for the AI features to work; the
# Tweaks panel's "AI Provider" selector only enables configured ones.

# Anthropic Claude
ANTHROPIC_API_KEY=

# Google Gemini
# Free key at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# Required for B2-FRED: macroeconomic data (CPI, Fed funds rate, etc.)
# Free key at https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=

# Required for B13-E: economic calendar + option chain (IV surface).
# Free key at https://finnhub.io/register — 60 calls/min on free tier.
FINNHUB_API_KEY=

# Optional: override Express server port (default: 3001)
# PORT=3001

# ── Supabase (B5-AU / B5-CR) ──────────────────────────────────────────────────
# All three variables must be set to enable Supabase auth + portfolio sync.
# Without them the dashboard runs in local-file mode with no login screen.

# Your Supabase project URL, e.g. https://xyzxyz.supabase.co
SUPABASE_URL=

# Public anon key (safe to expose client-side — returned by /api/auth/config)
SUPABASE_ANON_KEY=

# Service role key (server-only — used to validate JWTs and write portfolios)
# NEVER expose this to the browser / client side.
SUPABASE_SERVICE_ROLE_KEY=

# ── Google Drive Sync (B5-GS) ─────────────────────────────────────────────────
# Mirrors ~/.intelistock/portfolio.json into a Google Sheets file on every
# write. Local JSON stays the source of truth — Sheets is one-way.
#
# Setup:
#   1. console.cloud.google.com/apis/credentials → enable Google Sheets API.
#   2. Configure OAuth consent screen (External, Testing — add yourself as a test user).
#   3. Create an OAuth 2.0 Client ID, type = Web application.
#   4. Add http://localhost:3001/api/google/callback to "Authorized redirect URIs".
#   5. Paste the Client ID / Secret here, then click "Connect Google" in /settings.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Optional overrides (defaults are usually fine for a local MacBook host).
# GOOGLE_REDIRECT_URI=http://localhost:3001/api/google/callback
# GOOGLE_APP_URL=http://localhost:5180/settings
